    "n = int(input(\"Nhập n: \"))\n",
    "\n",
    "xoa = abs(n)\n",
    "dem = 0\n",
    "tong = 0\n",
    "\n",
    "if xoa == 0:\n",
    "    dem == 1\n",
    "else: \n",
    "    while xoa > 0:\n",
    "        dem += 1\n",
    "        tong += xoa % 10\n",
    "        xoa //= 10\n",
    "\n",
    "if n<2:\n",
    "    la_so_nguyen_to = False\n",
    "else:\n",
    "    la_so_nguyen_to = True\n",
    "    for i in range(2, n):\n",
    "        if n % i == 0:\n",
    "            la_so_nguyen_to = False\n",
    "            break\n",
    "\n",
    "print(\"Số chữ số: \", dem)\n",
    "print(\"Tổng chữ số: \", tong)\n",
    "\n",
    "if la_so_nguyen_to:\n",
    "    print(n, \"là số nguyên tố\")\n",
    "else:\n",
    "    print(n, \"không phải số nguyên tố\")"
   ]
